    },
    {
      "type": "command",
      "key": "о¬© Update",
      "keyColor": "magenta",
      "text": "last=$(softwareupdate --history 2>/dev/null | sed -n 's/^\\* //p' | tail -n 1); [ -n \"$last\" ] && echo \"$last\" || echo \"No history\""
