    {
      "type": "command",
      "key": "уұҰҹ OS Age",
      "keyColor": "magenta",
      "text": "created=$(stat -f %B / 2>/dev/null); if [ -n \"$created\" ] && [ \"$created\" -gt 0 ]; then echo $(( ($(date +%s) - created) / 86400 )) days; else echo unknown; fi"
    },
    {
      "type": "uptime",
