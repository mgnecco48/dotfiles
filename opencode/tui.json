{
    "$schema": "https://opencode.ai/tui.json",
    "theme": "lucent-org",
    "keybinds": {
        "app_exit": "ctrl+e",
        "help_show": "ctrl+h",
        "session_list": "ctrl+s",
        "session_rename": "ctrl+r",
        "variant_list": "ctrl+v",
    },
    "attention": {
        "enabled": true,
        "notifications": true,
        "sound": false,
        "volume": 0.4
    }
}
